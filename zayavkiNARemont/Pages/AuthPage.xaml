<Page x:Class="zayavkiNARemont.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Авторизация"
      Background="#F0F0F0">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Вход в систему" FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Логин" Margin="0,5"/>
        <TextBox Grid.Row="2" x:Name="tbLogin" Height="30" Margin="0,5"/>

        <TextBlock Grid.Row="3" Text="Пароль" Margin="0,5"/>
        <PasswordBox Grid.Row="4" x:Name="pbPassword" Margin="0,20,10,23"/>

        <Button Grid.Row="4" x:Name="btnLogin" Content="Войти" Margin="156,55,0,1" Click="BtnLogin_Click"
                Background="#2C3E50" Foreground="White">
            <UIElement.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                </TransformGroup>
            </UIElement.RenderTransform>
        </Button>
    </Grid>
</Page>