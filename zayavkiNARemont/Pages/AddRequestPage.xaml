<Page x:Class="zayavkiNARemont.Pages.AddRequestPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Новая заявка"
      Background="#F0F0F0">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#2C3E50" Padding="15">
            <Grid>
                <Button x:Name="btnBack" Content="Назад" Background="#7F8C8D" Foreground="White"
                        BorderThickness="0" Padding="10,5" Click="BtnBack_Click" Width="80" HorizontalAlignment="Left"/>
                <TextBlock Text="Новая заявка" FontSize="18" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button x:Name="btnSave" Content="Сохранить" Background="#27AE60" Foreground="White"
                        BorderThickness="0" Padding="10,5" Click="BtnSave_Click" Width="80" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="20" Margin="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Оборудование:" FontWeight="Bold" Margin="0,10"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cbEquipment" Margin="0,10"
                          DisplayMemberPath="name" SelectedValuePath="id"/>

                <TextBlock Grid.Row="1" Text="Серийный номер:" FontWeight="Bold" Margin="0,10"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="tbSerial" Margin="0,10"/>

                <TextBlock Grid.Row="2" Text="Тип неисправности:" FontWeight="Bold" Margin="0,10"/>
                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cbFaultType" Margin="0,10"
                          DisplayMemberPath="name" SelectedValuePath="id"/>

                <TextBlock Grid.Row="3" Text="Описание:" FontWeight="Bold" Margin="0,10"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="tbDescription" 
                         TextWrapping="Wrap" Height="100" AcceptsReturn="True" Margin="0,10"/>

                <TextBlock Grid.Row="4" Text="Приоритет:" FontWeight="Bold" Margin="0,10"/>
                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="cbPriority" Margin="0,10">
                    <ComboBoxItem Content="low"/>
                    <ComboBoxItem Content="medium" IsSelected="True"/>
                    <ComboBoxItem Content="high"/>
                    <ComboBoxItem Content="critical"/>
                </ComboBox>

                <TextBlock Grid.Row="5" Text="Плановый срок:" FontWeight="Bold" Margin="0,10"/>
                <DatePicker Grid.Row="5" Grid.Column="1" x:Name="dpDeadline" Margin="0,10"/>

                <TextBlock Grid.Row="6" Text="Исполнитель:" FontWeight="Bold" Margin="0,10" x:Name="tbExecutorLabel"/>
                <ComboBox Grid.Row="6" Grid.Column="1" x:Name="cbExecutor" Margin="0,10"
                          DisplayMemberPath="full_name" SelectedValuePath="id"/>
            </Grid>
        </Border>
    </Grid>
</Page>