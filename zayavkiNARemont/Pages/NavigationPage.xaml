<Page x:Class="zayavkiNARemont.Pages.NavigationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Главное меню"
      Background="#F0F0F0">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Background="#2C3E50" Padding="15">
            <Grid>
                <TextBlock Text="Учёт заявок на ремонт" FontSize="18" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock x:Name="tbUser" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button x:Name="btnLogout" Content="Выход" Background="#E74C3C" 
                            Foreground="White" BorderThickness="0" Padding="10,5" Click="BtnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Кнопки меню -->
        <WrapPanel x:Name="pnlMenu" Grid.Row="1" Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <!-- Нижняя информация -->
        <Border Grid.Row="2" Background="#DDD" Padding="10">
            <TextBlock x:Name="tbRole" TextAlignment="Center" FontSize="12"/>
        </Border>
    </Grid>
</Page>