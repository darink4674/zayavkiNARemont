<Page x:Class="zayavkiNARemont.Pages.RequestsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Заявки"
      Background="#F0F0F0">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Background="#2C3E50" Padding="15">
            <Grid>
                <Button x:Name="btnBack" Content="Назад" Background="#7F8C8D" Foreground="White"
                        BorderThickness="0" Padding="10,5" Click="BtnBack_Click" Width="80" HorizontalAlignment="Left"/>
                <TextBlock Text="Список заявок" FontSize="18" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Статистика (3 карточки) -->
        <Border Grid.Row="1" Background="White" Margin="10" Padding="10" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#E8F8F5" Margin="5" Padding="10" CornerRadius="5">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Всего заявок" Foreground="Gray"/>
                        <TextBlock x:Name="tbTotal" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#E8F8F5" Margin="5" Padding="10" CornerRadius="5">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Выполнено" Foreground="Gray"/>
                        <TextBlock x:Name="tbCompleted" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Green"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#E8F8F5" Margin="5" Padding="10" CornerRadius="5">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Ср. время (ч)" Foreground="Gray"/>
                        <TextBlock x:Name="tbAvgTime" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Blue"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Фильтры -->
        <Border Grid.Row="2" Background="White" Margin="10,0,10,10" Padding="10" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Поиск:" VerticalAlignment="Center"/>
                <TextBox x:Name="tbSearch" Grid.Column="1" Margin="5,0" Height="30"/>

                <TextBlock Grid.Column="2" Text="Статус:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <ComboBox x:Name="cbStatus" Grid.Column="3" Margin="5,0" Height="30">
                    <ComboBoxItem Content="Все"/>
                    <ComboBoxItem Content="waiting"/>
                    <ComboBoxItem Content="in_progress"/>
                    <ComboBoxItem Content="completed"/>
                    <ComboBoxItem Content="cancelled"/>
                    <ComboBoxItem Content="need_parts"/>
                </ComboBox>

                <Button Grid.Column="4" x:Name="btnSearch" Content="Найти" 
                        Background="#3498DB" Foreground="White" BorderThickness="0"
                        Padding="15,5" Click="BtnSearch_Click" Width="80" Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <!-- Таблица -->
        <ListView x:Name="lvRequests" Grid.Row="3" Margin="10" 
                  MouseDoubleClick="LvRequests_MouseDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="№" Width="80" DisplayMemberBinding="{Binding request_number}"/>
                    <GridViewColumn Header="Дата" Width="100" DisplayMemberBinding="{Binding created_date}"/>
                    <GridViewColumn Header="Оборудование" Width="120" DisplayMemberBinding="{Binding equipment_types.name}"/>
                    <GridViewColumn Header="Неисправность" Width="120" DisplayMemberBinding="{Binding fault_types.name}"/>
                    <GridViewColumn Header="Клиент" Width="150" DisplayMemberBinding="{Binding users.full_name}"/>
                    <GridViewColumn Header="Исполнитель" Width="150" DisplayMemberBinding="{Binding users1.full_name}"/>
                    <GridViewColumn Header="Статус" Width="100" DisplayMemberBinding="{Binding status}"/>
                    <GridViewColumn Header="Приоритет" Width="80" DisplayMemberBinding="{Binding priority}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>