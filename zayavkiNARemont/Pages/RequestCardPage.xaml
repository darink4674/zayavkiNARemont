<Page x:Class="zayavkiNARemont.Pages.RequestCardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Карточка заявки"
      Background="#F0F0F0">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Background="#2C3E50" Padding="15">
            <Grid>
                <Button x:Name="btnBack" Content="Назад" Background="#7F8C8D" Foreground="White"
                        BorderThickness="0" Padding="10,5" Click="BtnBack_Click" Width="80" HorizontalAlignment="Left"/>
                <TextBlock x:Name="tbTitle" Text="Заявка" FontSize="18" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button x:Name="btnSave" Content="Сохранить" Background="#27AE60" Foreground="White"
                        BorderThickness="0" Padding="10,5" Click="BtnSave_Click" Width="80" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Левая колонка - данные заявки -->
                <Border Background="White" CornerRadius="5" Padding="10" Margin="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Номер:" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Grid.Column="1" x:Name="tbNumber" Margin="0,5"/>

                        <TextBlock Grid.Row="1" Text="Дата:" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="tbDate" Margin="0,5"/>

                        <TextBlock Grid.Row="2" Text="Оборудование:" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="tbEquipment" Margin="0,5"/>

                        <TextBlock Grid.Row="3" Text="Серийный номер:" FontWeight="Bold" Margin="0,5"/>
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="tbSerial" Margin="0,5"/>

                        <TextBlock Grid.Row="4" Text="Неисправность:" FontWeight="Bold" Margin="0,5"/>
                        <ComboBox Grid.Row="4" Grid.Column="1" x:Name="cbFaultType" Margin="0,5"
                                  DisplayMemberPath="name" SelectedValuePath="id"/>

                        <TextBlock Grid.Row="5" Text="Описание:" FontWeight="Bold" Margin="0,5"/>
                        <TextBox Grid.Row="5" Grid.Column="1" x:Name="tbDescription" 
                                 TextWrapping="Wrap" Height="80" Margin="0,5"/>

                        <TextBlock Grid.Row="6" Text="Статус:" FontWeight="Bold" Margin="0,5"/>
                        <ComboBox Grid.Row="6" Grid.Column="1" x:Name="cbStatus" Margin="0,5">
                            <ComboBoxItem Content="waiting"/>
                            <ComboBoxItem Content="in_progress"/>
                            <ComboBoxItem Content="completed"/>
                            <ComboBoxItem Content="cancelled"/>
                            <ComboBoxItem Content="need_parts"/>
                        </ComboBox>

                        <TextBlock Grid.Row="7" Text="Приоритет:" FontWeight="Bold" Margin="0,5"/>
                        <ComboBox Grid.Row="7" Grid.Column="1" x:Name="cbPriority" Margin="0,5">
                            <ComboBoxItem Content="low"/>
                            <ComboBoxItem Content="medium"/>
                            <ComboBoxItem Content="high"/>
                            <ComboBoxItem Content="critical"/>
                        </ComboBox>

                        <TextBlock Grid.Row="8" Text="Исполнитель:" FontWeight="Bold" Margin="0,5"/>
                        <ComboBox Grid.Row="8" Grid.Column="1" x:Name="cbExecutor" Margin="0,5"
                                  DisplayMemberPath="full_name" SelectedValuePath="id"/>

                        <TextBlock Grid.Row="9" Text="Плановый срок:" FontWeight="Bold" Margin="0,5"/>
                        <DatePicker Grid.Row="9" Grid.Column="1" x:Name="dpDeadline" Margin="0,5"/>
                    </Grid>
                </Border>

                <!-- Правая колонка - комментарии -->
                <Border Grid.Row="0" Grid.Column="1" Background="White" CornerRadius="5" Padding="10" Margin="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Комментарии" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="1" Text="Новый комментарий:" Margin="0,5"/>
                        <TextBox Grid.Row="2" x:Name="tbNewComment" TextWrapping="Wrap" 
                                 MinHeight="80" AcceptsReturn="True" Margin="0,5"/>

                        <Button Grid.Row="3" x:Name="btnAddComment" Content="Добавить комментарий" 
                                Background="#3498DB" Foreground="White" BorderThickness="0"
                                Padding="10,5" Click="BtnAddComment_Click" Margin="0,10"/>

                        <ListView Grid.Row="4" x:Name="lvComments" Margin="0,10" MaxHeight="300">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Дата" Width="120" DisplayMemberBinding="{Binding created_at}"/>
                                    <GridViewColumn Header="Автор" Width="120" DisplayMemberBinding="{Binding users.full_name}"/>
                                    <GridViewColumn Header="Комментарий" Width="200" DisplayMemberBinding="{Binding comment_text}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>